#define ADMIN_VERB_REGISTER(path_name, admin_proc_path, admin_permissions, admin_visibility_flag, admin_storyteller_access, admin_paranoid_debug) \
/datum/admin_verb/registered_##path_name \
{ \
	permissions = ##admin_permissions; \
	visibility_flag = ##admin_visibility_flag; \
	allows_storyteller = ##admin_storyteller_access; \
	paranoid_debug = ##admin_paranoid_debug; \
	verb_path = ##admin_proc_path; \
}

